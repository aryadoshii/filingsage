# Production env file for the Oracle VM (docker-compose.prod.yml).
# Copy to .env.prod on the VM and fill in real values — .env.prod is
# gitignored and must never be committed.

ENV=prod

# Neon Postgres connection string. sslmode=require is mandatory — Neon
# rejects unencrypted connections, and this must use the psycopg driver
# (postgresql+psycopg://, matching Settings.database_url) not plain
# postgresql://.
DATABASE_URL=postgresql+psycopg://user:password@ep-example-12345.us-east-2.aws.neon.tech/filingsage?sslmode=require

# Upstash Redis connection string. Must use the rediss:// (TLS) scheme —
# Upstash requires TLS; plain redis:// will fail to connect.
REDIS_URL=rediss://default:password@example-12345.upstash.io:6379

# REQUIRED before any EDGAR ingestion runs — SEC fair-access policy.
SEC_CONTACT_EMAIL=doshiarya27@gmail.com

# Shared secret for POST /internal/ingest, called by .github/workflows/ingest-cron.yml.
# Generate a FRESH value for prod — never reuse the dev .env's token:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_TOKEN=
