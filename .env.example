ENV=dev

# Local dev Postgres (compose service). Prod uses Neon — different URL, same var.
POSTGRES_USER=filingsage
POSTGRES_PASSWORD=filingsage
POSTGRES_DB=filingsage
DATABASE_URL=postgresql://filingsage:filingsage@postgres:5432/filingsage

# Local dev Redis (compose service). Prod uses Upstash.
REDIS_URL=redis://redis:6379/0

# REQUIRED before any EDGAR ingestion runs — SEC fair-access policy.
SEC_CONTACT_EMAIL=you@example.com
